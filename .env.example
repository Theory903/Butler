# Butler Backend Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit the actual .env file to version control

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Application environment: development, staging, production
APP_ENV=development

# Application name
APP_NAME=butler

# Application version (auto-incremented by CI/CD)
APP_VERSION=1.0.0

# Debug mode (only set to true in development)
DEBUG=true

# Server host and port
HOST=0.0.0.0
PORT=8000

# API base URL (auto-generated from HOST:PORT if not set)
API_BASE_URL=http://localhost:8000

# CORS origins (comma-separated, leave empty to allow all)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# =============================================================================
# TENANT PROVIDER CONFIGURATION
# =============================================================================
# Default tenant ID for single-tenant deployments
DEFAULT_TENANT_ID=default

# Provider encryption key for encrypting custom API keys at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROVIDER_ENCRYPTION_KEY=your-provider-encryption-key-here-generate-with-fernet

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://butler:butler_password@localhost:5432/butler

# PostgreSQL pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis connection string
# Format: redis://host:port/db or redis://:password@host:port/db
REDIS_URL=redis://localhost:6379/0

# Redis pool settings
REDIS_POOL_SIZE=10
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT secret key (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production

# JWT algorithm (RS256 recommended for production, HS256 for development)
JWT_ALGORITHM=HS256

# JWT issuer
JWT_ISSUER=butler

# JWT audience
JWT_AUDIENCE=butler-users

# JWT access token expiration (in minutes)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT refresh token expiration (in days)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing (argon2id recommended)
PASSWORD_HASHER=argon2id

# Password hash memory cost (argon2)
ARGON2_MEMORY_COST=65536

# Password hash time cost (argon2)
ARGON2_TIME_COST=3

# Password hash parallelism (argon2)
ARGON2_PARALLELISM=4

# =============================================================================
# ML RUNTIME PROVIDER ORCHESTRATION (OpenClaw-inspired Layer)
# =============================================================================
# Enable/disable provider orchestration
PROVIDER_ORCHESTRATION_ENABLED=true

# Retry policy
PROVIDER_MAX_RETRIES=3
PROVIDER_INITIAL_DELAY=1.0
PROVIDER_BACKOFF_FACTOR=2.0
PROVIDER_MAX_DELAY=30.0
PROVIDER_RETRY_JITTER=true

# Circuit breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
CIRCUIT_BREAKER_HALF_OPEN=3

# Rate limiting
PROVIDER_RPM=60
PROVIDER_RPH=3600
PROVIDER_BURST=10

# Observability
PROVIDER_OBSERVABILITY=true
PROVIDER_COST_TRACKING=true
PROVIDER_TIMEOUT=120
PROVIDER_LOG_LEVEL=INFO

# =============================================================================
# LLM PROVIDER CREDENTIALS (for ML Runtime Orchestration)
# =============================================================================
# These credentials are used by the ProviderOrchestrator for failover and load balancing

# OpenAI credentials (can have multiple keys for load balancing)
# Format: OPENAI_API_KEY_1, OPENAI_API_KEY_2, etc.
OPENAI_API_KEY_1=sk-your-openai-key-1
OPENAI_API_KEY_2=sk-your-openai-key-2

# Anthropic credentials
ANTHROPIC_API_KEY_1=sk-ant-your-anthropic-key-1
ANTHROPIC_API_KEY_2=sk-ant-your-anthropic-key-2

# Groq credentials
GROQ_API_KEY_1=gsk_your-groq-key-1
GROQ_API_KEY_2=gsk_your-groq-key-2

# Vertex AI credentials (uses Google Cloud credentials)
# Set GOOGLE_APPLICATION_CREDENTIALS path or use Application Default Credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# OpenRouter credentials
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
# Default provider to use
DEFAULT_LLM_PROVIDER=openai

# Default model for each provider
DEFAULT_OPENAI_MODEL=gpt-5.2
DEFAULT_ANTHROPIC_MODEL=claude-opus-4-6
DEFAULT_GROQ_MODEL=llama-3.3-70b-versatile
DEFAULT_VERTEX_MODEL=gemini-2.5-flash
DEFAULT_OPENROUTER_MODEL=anthropic/claude-opus-4-6

# LLM temperature
LLM_TEMPERATURE=0.7

# LLM max tokens
LLM_MAX_TOKENS=4096

# LLM timeout (seconds)
LLM_TIMEOUT=120

# =============================================================================
# VECTOR DATABASE (Qdrant)
# =============================================================================
# Qdrant host
QDRANT_HOST=localhost

# Qdrant port
QDRANT_PORT=6333

# Qdrant API key (if using cloud)
QDRANT_API_KEY=

# Qdrant collection name for embeddings
QDRANT_COLLECTION_NAME=butler_embeddings

# Embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Embedding dimension
EMBEDDING_DIMENSION=384

# =============================================================================
# NEO4J GRAPH DATABASE
# =============================================================================
# Neo4j connection URI
NEO4J_URI=bolt://localhost:7687

# Neo4j username
NEO4J_USERNAME=neo4j

# Neo4j password
NEO4J_PASSWORD=your-neo4j-password

# =============================================================================
# OBJECT STORAGE (AWS S3 or compatible)
# =============================================================================
# AWS access key ID
AWS_ACCESS_KEY_ID=your-aws-access-key

# AWS secret access key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# AWS region
AWS_REGION=us-east-1

# S3 bucket name
S3_BUCKET_NAME=butler-storage

# S3 endpoint (for S3-compatible services like MinIO)
S3_ENDPOINT_URL=

# =============================================================================
# KAFKA (Event Streaming)
# =============================================================================
# Kafka bootstrap servers
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Kafka consumer group
KAFKA_CONSUMER_GROUP=butler-consumers

# =============================================================================
# OPEN TELEMETRY (Observability)
# =============================================================================
# Enable OpenTelemetry tracing
OTEL_ENABLED=false

# OpenTelemetry endpoint
OTEL_ENDPOINT=http://localhost:4317

# OpenTelemetry service name
OTEL_SERVICE_NAME=butler-backend

# OpenTelemetry sampling rate (0.0 to 1.0)
OTEL_SAMPLING_RATE=1.0

# =============================================================================
# PROMETHEUS METRICS
# =============================================================================
# Enable Prometheus metrics
PROMETHEUS_ENABLED=true

# Prometheus metrics endpoint
PROMETHEUS_METRICS_PATH=/metrics

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=json

# Log file path (leave empty to log to stdout)
LOG_FILE=

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================
# Session expiration (in minutes)
SESSION_EXPIRE_MINUTES=60

# Session cookie name
SESSION_COOKIE_NAME=butler_session

# Session cookie domain
SESSION_COOKIE_DOMAIN=

# Session cookie secure flag (set to true in production)
SESSION_COOKIE_SECURE=false

# Session cookie same-site policy: lax, strict, none
SESSION_COOKIE_SAME_SITE=lax

# =============================================================================
# FILE STORAGE
# =============================================================================
# Upload directory
UPLOAD_DIR=/tmp/butler/uploads

# Max file upload size (in MB)
MAX_UPLOAD_SIZE=100

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=txt,pdf,doc,docx,md,json,yaml,yml

# =============================================================================
# RATE LIMITING (API)
# =============================================================================
# Global rate limit (requests per minute)
GLOBAL_RATE_LIMIT=100

# Per-user rate limit (requests per minute)
USER_RATE_LIMIT=60

# =============================================================================
# WORKFLOW CONFIGURATION
# =============================================================================
# Maximum workflow iterations
MAX_WORKFLOW_ITERATIONS=50

# Workflow timeout (in seconds)
WORKFLOW_TIMEOUT=300

# =============================================================================
# TOOL CONFIGURATION
# =============================================================================
# Enable dangerous tools (file operations, shell commands, etc.)
ENABLE_DANGEROUS_TOOLS=false

# Tool timeout (in seconds)
TOOL_TIMEOUT=60

# =============================================================================
# BACKGROUND TASKS
# =============================================================================
# Enable background task processing
ENABLE_BACKGROUND_TASKS=true

# Background task worker count
BACKGROUND_TASK_WORKERS=4

# =============================================================================
# WEBHOOK CONFIGURATION
# =============================================================================
# Webhook secret for signature verification
WEBHOOK_SECRET=your-webhook-secret

# Webhook timeout (in seconds)
WEBHOOK_TIMEOUT=30

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=false

# Enable beta features
ENABLE_BETA_FEATURES=false

# =============================================================================
# HERMES INTEGRATION (Optional)
# =============================================================================
# Enable Hermes agent integration
HERMES_ENABLED=false

# Hermes configuration path
HERMES_CONFIG_PATH=~/.hermes/config.yaml

# Hermes .env path
HERMES_ENV_PATH=~/.hermes/.env

# =============================================================================
# MOBILE APP (React Native)
# =============================================================================
# Mobile API base URL (for Expo app to connect to backend)
MOBILE_API_URL=http://localhost:8000

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================
# Enable auto-reload on code changes
AUTO_RELOAD=true

# Enable debug toolbar (only in development)
DEBUG_TOOLBAR=true

# Enable SQL query logging
SQL_ECHO=false
